# Upbit API
UPBIT_ACCESS_KEY=your_access_key
UPBIT_SECRET_KEY=your_secret_key

# Kiwoom API (Phase 4)
KIWOOM_APP_KEY=your_app_key
KIWOOM_APP_SECRET=your_app_secret
KIWOOM_ACCOUNT_NO=your_account_no
KIWOOM_IS_PAPER=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Discord Webhook (Phase 3)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Anthropic API (Phase 5)
ANTHROPIC_API_KEY=your_api_key

# Database
DB_PATH=data/trading.db

# Swarm Consensus (Phase 6) — AI API 키 설정 시에만 동작
SWARM_ENABLED=false        # true로 변경하면 3-에이전트 합의 활성화
SWARM_QUORUM=2             # 3개 중 몇 개 approve 시 실행 (기본 2)
SWARM_MIN_CONFIDENCE=0.4   # 이 값 미만 신호는 합의 없이 차단
